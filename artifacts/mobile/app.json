{
  "expo": {
    "name": "طيباتي - Tayyibati",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tayyibati",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B7A5E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tayyibati.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "يستخدم التطبيق الكاميرا لتصوير الأطعمة والملصقات وتحليل مكوناتها وفق نظام الطيبات.",
        "NSPhotoLibraryUsageDescription": "يستخدم التطبيق معرض الصور لاختيار صور الأطعمة والملصقات وتحليل مكوناتها.",
        "NSPhotoLibraryAddUsageDescription": "يستخدم التطبيق معرض الصور لاختيار صور الأطعمة والملصقات وتحليل مكوناتها.",
        "CFBundleLocalizations": ["ar"],
        "CFBundleDevelopmentRegion": "ar_SA"
      }
    },
    "android": {
      "package": "com.tayyibati.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1B7A5E"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "يستخدم التطبيق معرض الصور لاختيار صور الأطعمة والملصقات.",
          "cameraPermission": "يستخدم التطبيق الكاميرا لتصوير الأطعمة والملصقات."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    },
    "notification": {
      "icon": "./assets/images/icon.png",
      "color": "#1B7A5E"
    }
  }
}
